{
  "HTML Document": {
    "prefix": "html",
    "body": [
      "<!DOCTYPE html>",
      "<html lang=\"en\">",
      "",
      "<head>",
      "  <meta charset=\"UTF-8\">",
      "  <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">",
      "  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">",
      "  <title>${1:Hello, world}</title>",
      "  <meta name=\"description\" content=\"${2:Page description}\">",
      "  <link rel=\"canonical\" href=\"https://${3:example.com}\">",
      "  <link rel=\"icon\" href=\"${4:favicon.svg}\">",
      "</head>",
      "",
      "<body>",
      "  <h1>${5:Hello, world.}</h1>",
      "  ${6}",
      "</body>",
      "",
      "</html>"
    ],
    "description": "Start an HTML document"
  },

  "HTML Open Graph Tags": {
    "prefix": "meta-og",
    "body": [
      "<meta property=\"og:title\" content=\"${1:Page Title}\">",
      "<meta property=\"og:description\" content=\"${2:Page description}\">",
      "<meta property=\"og:image\" content=\"https://${3:example.com/image.jpg}\">",
      "<meta property=\"og:url\" content=\"https://${4:example.com}\">",
      "<meta property=\"og:type\" content=\"${5|website,article,profile|}\">"
    ],
    "description": "Open Graph meta tags"
  },

  "HTML Twitter Card Tags": {
    "prefix": "meta-twitter",
    "body": [
      "<meta name=\"twitter:card\" content=\"${1|summary,summary_large_image|}\">",
      "<meta name=\"twitter:title\" content=\"${2:Page Title}\">",
      "<meta name=\"twitter:description\" content=\"${3:Page description}\">",
      "<meta name=\"twitter:image\" content=\"https://${4:example.com/image.jpg}\">"
    ],
    "description": "Twitter Card meta tags"
  },

  "HTML Script Tag": {
    "prefix": "script-src",
    "body": [
      "<script src=\"${1:app.js}\" ${2|defer,async|}></script>"
    ],
    "description": "Script tag with src"
  },

  "HTML Stylesheet Link": {
    "prefix": "link",
    "body": [
      "<link rel=\"stylesheet\" href=\"${1:styles.css}\">"
    ],
    "description": "Stylesheet link tag"
  },

  "HTML Font Face": {
    "prefix": "font-face",
    "body": [
      "@font-face {",
      "  font-family: '${1:FontName}';",
      "  src: url('${2:fonts/fontname.woff2}') format('woff2'),",
      "       url('${3:fonts/fontname.woff}') format('woff');",
      "  font-weight: ${4|normal,bold,100,200,300,400,500,600,700,800,900|};",
      "  font-style: ${5|normal,italic|};",
      "  font-display: ${6|swap,auto,block,fallback,optional|};",
      "}"
    ],
    "description": "Self-hosted @font-face block"
  },

  "HTML Style Block": {
    "prefix": "style",
    "body": [
      "<style>",
      "  ${1}",
      "</style>"
    ],
    "description": "Inline style block"
  },

  "HTML Script Block": {
    "prefix": "script",
    "body": [
      "<script>",
      "  ${1}",
      "</script>"
    ],
    "description": "Inline script block"
  },

  "HTML Layout": {
    "prefix": "html-layout",
    "body": [
      "<header>",
      "  ${1}",
      "</header>",
      "",
      "<main>",
      "  ${2}",
      "</main>",
      "",
      "<footer>",
      "  ${3}",
      "</footer>"
    ],
    "description": "Basic HTML page layout"
  },

  "HTML Layout with Sidebar": {
    "prefix": "html-layout-sidebar",
    "body": [
      "<header>",
      "  ${1}",
      "</header>",
      "",
      "<aside>",
      "  ${2}",
      "</aside>",
      "",
      "<main>",
      "  ${3}",
      "</main>",
      "",
      "<footer>",
      "  ${4}",
      "</footer>"
    ],
    "description": "HTML page layout with sidebar"
  },

  "HTML Favicon Block": {
    "prefix": "html-favicon",
    "body": [
      "<link rel=\"manifest\" href=\"/manifest.json\">",
      "<link rel=\"apple-touch-icon\" sizes=\"180x180\" href=\"/apple-touch-icon.png\">",
      "<link rel=\"icon\" type=\"image/png\" sizes=\"32x32\" href=\"/favicon-32x32.png\">",
      "<link rel=\"icon\" type=\"image/png\" sizes=\"16x16\" href=\"/favicon-16x16.png\">",
      "<link rel=\"mask-icon\" href=\"/safari-pinned-tab.svg\" color=\"${1:#000000}\">",
      "<meta name=\"msapplication-TileColor\" content=\"${2:#000000}\">",
      "<meta name=\"theme-color\" content=\"${3:#ffffff}\">"
    ],
    "description": "Favicon and app icon meta tags"
  },

  "Google Fonts": {
    "prefix": "link-google-fonts",
    "body": [
      "<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">",
      "<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>",
      "<link href=\"${1:https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap}\" rel=\"stylesheet\">"
    ],
    "description": "Google Fonts with preconnect"
  },

  "PWA Meta Tags": {
    "prefix": "meta-pwa",
    "body": [
      "<meta name=\"apple-mobile-web-app-capable\" content=\"yes\">",
      "<meta name=\"apple-mobile-web-app-status-bar-style\" content=\"${1|black,default,black-translucent|}\">",
      "<meta name=\"apple-mobile-web-app-title\" content=\"${2:App Title}\">",
      "<meta name=\"theme-color\" content=\"${3:#ffffff}\">"
    ],
    "description": "PWA and Apple web app meta tags"
  }
}