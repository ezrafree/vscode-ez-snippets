{
  "Arrow Function": {
    "prefix": "const-arrow",
    "body": [
      "const ${1:name} = (${2:params}) => {",
      "  ${3:return true;}",
      "}"
    ],
    "description": "Arrow function"
  },

  "Arrow Function (implicit return)": {
    "prefix": "const-arrow-implicit",
    "body": [
      "const ${1:name} = (${2:params}) => ${3:value};"
    ],
    "description": "Arrow function with implicit return"
  },

  "Async Arrow Function": {
    "prefix": "const-arrow-async",
    "body": [
      "const ${1:name} = async (${2:params}) => {",
      "  ${3}",
      "}"
    ],
    "description": "Async arrow function"
  },

  "Try Catch": {
    "prefix": "try-catch",
    "body": [
      "try {",
      "  ${1}",
      "} catch (${2:error}) {",
      "  console.error(${2:error})",
      "}"
    ],
    "description": "Try catch block"
  },

  "Destructure Array": {
    "prefix": "destructure-array",
    "body": [
      "const [${1:a}, ${2:b}] = ${3:array}"
    ],
    "description": "Array destructuring"
  },

  "Destructure Object": {
    "prefix": "destructure-object",
    "body": [
      "const { ${1:a}, ${2:b} } = ${3:object}"
    ],
    "description": "Object destructuring"
  },

  "Promise": {
    "prefix": "promise",
    "body": [
      "new Promise((resolve, reject) => {",
      "  ${1}",
      "})"
    ],
    "description": "New Promise"
  },

  "Promise.all": {
    "prefix": "promise-all",
    "body": [
      "Promise.all([${1}])"
    ],
    "description": "Promise.all"
  },

  "Fetch": {
    "prefix": "fetch",
    "body": [
      "const response = await fetch('${1:url}')",
      "const data = await response.json()"
    ],
    "description": "Fetch with await and json parsing"
  },

  "Ternary": {
    "prefix": "ternary",
    "body": [
      "const ${1:name} = ${2:condition} ? ${3:true} : ${4:false}"
    ],
    "description": "Ternary operator"
  },

  "Nullish Coalescing": {
    "prefix": "nullish",
    "body": [
      "const ${1:value} = ${2:a} ?? ${3:b}"
    ],
    "description": "Nullish coalescing operator"
  },

  "Optional Chaining": {
    "prefix": "optional-chain",
    "body": [
      "${1:obj}?.${2:property}"
    ],
    "description": "Optional chaining"
  },

  "For Of": {
    "prefix": "for-of",
    "body": [
      "for (const ${1:item} of ${2:items}) {",
      "  ${3}",
      "}"
    ],
    "description": "For of loop"
  },

  "For In": {
    "prefix": "for-in",
    "body": [
      "for (const ${1:key} in ${2:object}) {",
      "  ${3}",
      "}"
    ],
    "description": "For in loop"
  },

  "setTimeout": {
    "prefix": "settimeout",
    "body": [
      "setTimeout(() => {",
      "  ${1}",
      "}, ${2:1000})"
    ],
    "description": "setTimeout"
  },

  "setInterval": {
    "prefix": "setinterval",
    "body": [
      "setInterval(() => {",
      "  ${1}",
      "}, ${2:1000})"
    ],
    "description": "setInterval"
  },

  "importStatement": {
    "prefix": "import-default",
    "body": [
      "import ${2:moduleName} from '${1:module}'$0"
    ],
    "description": "Import default export"
  },

  "importNamed": {
    "prefix": "import-named",
    "body": [
      "import { $2 } from '${1:module}'$0"
    ],
    "description": "Import named export"
  },

  "localStorage getItem": {
    "prefix": "localstorage-get",
    "body": [
      "JSON.parse(localStorage.getItem('${1:key}'))"
    ],
    "description": "localStorage getItem with JSON parse"
  },

  "localStorage setItem": {
    "prefix": "localstorage-set",
    "body": [
      "localStorage.setItem('${1:key}', JSON.stringify(${2:value}))"
    ],
    "description": "localStorage setItem with JSON stringify"
  },

    "consoleLogNamed": {
    "prefix": "console-log-named",
    "body": [
      "console.log('$1: ', $1)"
    ],
    "description": "Named console log"
  },

  "consoleLog": {
    "prefix": "console-log",
    "body": [
      "console.log($1)"
    ],
    "description": "Console log"
  },

  "consoleLogJson": {
    "prefix": "console-log-json",
    "body": [
      "console.log(JSON.stringify($1, null, 2))"
    ],
    "description": "Console log pretty json"
  },

  "consoleLogObject": {
    "prefix": "console-log-object",
    "body": [
      "console.log({ $1 })"
    ],
    "description": "Console log object"
  },

  "consoleLogEslint": {
    "prefix": "console-log-eslint-disable",
    "body": [
      "// eslint-disable-next-line no-console\nconsole.log('$1: ', $1)"
    ],
    "description": "Console log with eslint disable comment"
  },

  "eslintDisable": {
    "prefix": "eslint-disable",
    "body": [
      "/* eslint-disable @typescript-eslint/no-unused-vars */"
    ],
    "description": "ESLint disable rule"
  },

  "eslintDisableNextLine": {
    "prefix": "eslint-disable-nextline",
    "body": [
      "/* eslint-disable-next-line @typescript-eslint/no-unused-vars */"
    ],
    "description": "ESLint disable rule on next line"
  }
}