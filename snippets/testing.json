{
  "Unit Test File": {
    "prefix": "test-file",
    "body": [
      "import { ${1:render} } from '${2:@testing-library/react}'",
      "import React from 'react'",
      "",
      "import { ${3:namedExport} } from '${4:module}'",
      "",
      "describe('${5:Suite Name}', () => {",
      "  beforeEach(() => {})",
      "  it('${6:Spec Name}', () => {",
      "    ${7:// do something}",
      "  })",
      "})"
    ],
    "description": "Unit test boilerplate"
  },

  "Unit Test Describe": {
    "prefix": "test-describe",
    "body": [
      "  describe('${1:Suite Name}', () => {",
      "    ${2:// do something}",
      "  })"
    ],
    "description": "Unit Test Suite"
  },

  "Unit Test Spec": {
    "prefix": "test-spec",
    "body": [
      "  it('${1:Spec Name}', () => {",
      "    ${2:// do something}",
      "  })"
    ],
    "description": "Unit Test Spec"
  },

  "Unit Test Assert": {
    "prefix": "test-assert",
    "body": [
      "  expect(${1:variable}).toEqual(${2:result})"
    ],
    "description": "Unit Test Assertion"
  }
}